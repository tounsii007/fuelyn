{
  "name": "fuelyn",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@fuelyn/web",
    "dev:mobile": "turbo run dev --filter=@fuelyn/mobile",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean",
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/web/src/**/*.{ts,tsx}": [
      "eslint --max-warnings=0 --fix"
    ],
    "packages/core/src/**/*.{ts,tsx}": [
      "eslint --max-warnings=0 --fix"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/leaflet.markercluster": "^1.5.6",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "husky": "9.1.7",
    "lint-staged": "^17.0.7",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "overrides": {
    "postcss": "^8.5.15",
    "yaml": "^2.9.0",
    "ws": "^8.21.0",
    "@hono/node-server": "^2.0.5",
    "uuid": "^14.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@11.17.0"
}
