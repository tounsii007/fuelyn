{
  "name": "fuelyn",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@fuelyn/web",
    "dev:mobile": "turbo run dev --filter=@fuelyn/mobile",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/leaflet.markercluster": "^1.5.6",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "turbo": "^2.9.6",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.8.0"
}
