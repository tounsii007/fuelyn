{
  "name": "fuelyn",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@fuelyn/web",
    "dev:mobile": "turbo run dev --filter=@fuelyn/mobile",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean",
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/web/src/**/*.{ts,tsx}": [
      "eslint --max-warnings=0 --fix"
    ],
    "packages/core/src/**/*.{ts,tsx}": [
      "eslint --max-warnings=0 --fix"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/leaflet.markercluster": "^1.5.6",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "husky": "9.1.7",
    "lint-staged": "^15.5.2",
    "turbo": "^2.9.14",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "yaml": "^2.8.3",
    "ws": "^8.20.1",
    "@hono/node-server": "^1.19.13"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.8.0"
}
