## ── Node / Next ─────────────────────────────
node_modules/
**/node_modules/
.next/
**/.next/
out/
.turbo/
**/.turbo/
*.tsbuildinfo
**/*.tsbuildinfo
.cache/

## ── Java ────────────────────────────────────
target/
**/target/
*.class
*.jar
*.war
hs_err_pid*

## ── Tests / Coverage ────────────────────────
coverage/
**/coverage/
*.lcov
.nyc_output

## ── Logs ────────────────────────────────────
*.log
logs/
npm-debug.log*

## ── Env / Secrets ───────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
*.crt
!apps/web/certificates/*.example.pem

## ── Build output ────────────────────────────
# packages/core publishes from src/ directly, dist/ is only built
# locally for IDE inspection — never committed.
packages/*/dist/
**/dist/

## ── DB / data ───────────────────────────────
backend/price-service/data/
backend/*/data/
*.h2.db
*.mv.db
*.trace.db
# Legacy web-BFF SQLite artifacts — persistence is Postgres now, but
# guard against re-committing a stray dev.db / template if anyone runs
# an old `prisma db push` against a file: URL.
apps/web/prisma/*.db
apps/web/prisma/*.db.template
*.sqlite
*.sqlite3

## ── IDE / Tooling ───────────────────────────
.idea/
.vscode/
*.iml
.project
.classpath
.settings/
.claude/

## ── OS ──────────────────────────────────────
.DS_Store
Thumbs.db
