# Tankerkoenig API Key — get yours at https://creativecommons.tankerkoenig.de/
# NEVER expose this in client-side code. It is only used in the BFF API routes.
TANKERKOENIG_API_KEY=your-api-key-here

# ──────────────────────────────────────────────────────────────
# Persistence — PostgreSQL (Prisma + @prisma/adapter-pg)
# ──────────────────────────────────────────────────────────────
# The web BFF persists to its OWN logical database `fuelyn_web`. In
# local dev this is the Postgres started by docker-compose.dev.yml,
# reachable on localhost:25432. `npm run dev` expects it to be up once
# a route actually queries the DB (see README → "Lokale Entwicklung").
# The unit-test suite does not need a live DB.
#
# In production the value is injected by docker-compose.yml and points
# at the in-network `postgres` host; an empty or `file:` URL is rejected
# by the runtime DB guard.
DATABASE_URL=postgresql://fuelyn:fuelyn@localhost:25432/fuelyn_web

# ──────────────────────────────────────────────────────────────
# AI advisor — tiered pipeline (Heuristic → Ollama → OpenAI)
# ──────────────────────────────────────────────────────────────

# Master enrichment switch. false = heuristic-only, no LLM ever.
AI_ENRICHMENT_ENABLED=true

# Provider order, CSV. The first one that's available + healthy wins.
AI_PROVIDERS=ollama,openai

# Ollama (local, free, private). Defaults to the premium-local profile:
# qwen2.5:7b-instruct (~4.7 GB on disk, 8–10 GB resident).
# Slim alternative: qwen2.5:3b-instruct (~2 GB / ~4 GB resident).
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_TIMEOUT_MS=60000
OLLAMA_KEEP_ALIVE=2h
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_MEMORY_LIMIT=12G
OLLAMA_MEMORY_RESERVATION=6G

# OpenAI premium tier — used only if Ollama fails AND a key is set.
# NEVER expose this in client-side code. It is only used in server-side API routes.
OPENAI_ENABLED=false
OPENAI_API_KEY=sk-...
