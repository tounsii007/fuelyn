# Tankerkoenig API Key — get yours at https://creativecommons.tankerkoenig.de/
# NEVER expose this in client-side code. It is only used in the BFF API routes.
TANKERKOENIG_API_KEY=your-api-key-here

# ──────────────────────────────────────────────────────────────
# Persistence — PostgreSQL (Prisma + @prisma/adapter-pg)
# ──────────────────────────────────────────────────────────────
# The web BFF persists to its OWN logical database `fuelyn_web`. In
# local dev this is the Postgres started by docker-compose.dev.yml,
# reachable on localhost:25432. `npm run dev` expects it to be up once
# a route actually queries the DB (see README → "Lokale Entwicklung").
# The unit-test suite does not need a live DB.
#
# In production the value is injected by docker-compose.yml and points
# at the in-network `postgres` host; an empty or `file:` URL is rejected
# by the runtime DB guard.
DATABASE_URL=postgresql://fuelyn:fuelyn@localhost:25432/fuelyn_web

# ──────────────────────────────────────────────────────────────
# AI advisor — tiered pipeline (Heuristic → Ollama → OpenAI)
# ──────────────────────────────────────────────────────────────

# Master enrichment switch. false = heuristic-only, no LLM ever.
AI_ENRICHMENT_ENABLED=true

# Provider order, CSV. The first one that's available + healthy wins.
AI_PROVIDERS=ollama,openai

# Ollama (local, free, private). Defaults to the premium-local profile:
# qwen2.5:7b-instruct (~4.7 GB on disk, 8–10 GB resident).
# Slim alternative: qwen2.5:3b-instruct (~2 GB / ~4 GB resident).
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_TIMEOUT_MS=60000
OLLAMA_KEEP_ALIVE=2h
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_MEMORY_LIMIT=12G
OLLAMA_MEMORY_RESERVATION=6G

# OpenAI premium tier — used only if Ollama fails AND a key is set.
# NEVER expose this in client-side code. It is only used in server-side API routes.
OPENAI_ENABLED=false
OPENAI_API_KEY=sk-...

# ──────────────────────────────────────────────────────────────
# Rate limiting
# ──────────────────────────────────────────────────────────────
# Shared cross-instance limiter store. When set, every BFF rate limit
# (magic-link, sync, AI, billing, …) is enforced in Redis so the cap
# holds across serverless / multi-instance / multi-region deploys.
# Leave UNSET for local dev / single-instance — the limiter falls back
# to a per-process in-memory store (and degrades to it automatically if
# Redis becomes unreachable).
# REDIS_URL=redis://localhost:6379

# Trust X-Forwarded-For / X-Real-IP for the client key. Set to 1 ONLY
# when the app sits behind a proxy you control — otherwise clients can
# spoof these headers to dodge the limit. Unset → all direct traffic
# shares one conservative bucket.
# RATE_LIMIT_TRUST_PROXY=1

# ──────────────────────────────────────────────────────────────
# Auth — magic-link sign-in
# ──────────────────────────────────────────────────────────────
# Public origin used to build the magic-link URL (and Stripe return
# URLs). MUST be an https:// origin in production — never derived from
# the request Origin header, which is attacker-controlled.
# FUELYN_PUBLIC_ORIGIN=https://app.fuelyn.example

# SMTP transport for magic-link emails (nodemailer connection URL).
# REQUIRED in production — POST /api/auth/magic-link returns 503 without
# it. Unset in dev → the link is logged + echoed in the response instead
# of emailed (dev stub).
# MAIL_TRANSPORT=smtps://user:pass@smtp.example.com:465

# Envelope From for transactional email. Defaults to
# "Fuelyn <no-reply@fuelyn.app>".
# MAIL_FROM=Fuelyn <login@fuelyn.app>

# ──────────────────────────────────────────────────────────────
# Billing — Stripe (Premium subscription)
# ──────────────────────────────────────────────────────────────
# Server-side secret key. Without it, /api/billing/checkout returns a
# dev STUB (no charge) so the upgrade flow is still testable. NEVER
# expose client-side.
# STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret for /api/billing/webhook (Stripe CLI:
# `stripe listen --forward-to localhost:3000/api/billing/webhook`).
# STRIPE_WEBHOOK_SECRET=whsec_...

# One-time setup: create the "Fuelyn Premium" product + prices
# (fuelyn-monthly €1.99 / fuelyn-annual €19.99) via:
#   STRIPE_SECRET_KEY=sk_test_... npm run stripe:setup   (add --dry-run to preview)
# The checkout resolves these lookup keys → price IDs at request time.
